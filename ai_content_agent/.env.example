# Copy this file to `.env` and fill in your real keys.
# Never commit `.env` — it's gitignored.

ANTHROPIC_API_KEY=sk-ant-...

# Optional. Defaults to claude-sonnet-4-6 if unset.
IVYEDGE_MODEL=claude-sonnet-4-6

# Substack session cookie — required for --publish
# Get it from: Chrome DevTools → Application → Cookies → substack.com → substack.sid
SUBSTACK_SID=...

# ── Meta (Instagram + Threads) ─────────────────────────────────────────────
# Long-lived page/user access token — generate at developers.facebook.com
META_ACCESS_TOKEN=...
# Instagram Business account numeric user ID
IG_USER_ID=...
# Threads user ID (same as IG_USER_ID in most setups)
THREADS_USER_ID=...

# Cloudinary — used to host media before passing URLs to the Meta API
# Free tier at cloudinary.com is sufficient for this volume
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...

# ElevenLabs — required only for video voiceover generation
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=...

# ── Email digest ───────────────────────────────────────────────────────────
# Where to send the daily engagement brief
NOTIFY_EMAIL=you@gmail.com

# Gmail sender account (must have 2FA enabled)
EMAIL_FROM=you@gmail.com
# Generate at: myaccount.google.com/apppasswords → "Mail" → your Mac
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Override SMTP provider (defaults to Gmail)
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587

# ── TikTok ─────────────────────────────────────────────────────────────────
# Optional: improves TikTok discovery results (avoids bot detection)
# Get it by logging into TikTok in Chrome → DevTools → Application →
# Cookies → tiktok.com → find "msToken" → copy the value
TIKTOK_MS_TOKEN=

# ── Reddit ─────────────────────────────────────────────────────────────────
# 1. Go to https://www.reddit.com/prefs/apps and create a "script" app
# 2. Set redirect URI to http://localhost:8080
# 3. Copy the client_id (shown under the app name) and secret
REDDIT_CLIENT_ID=...
REDDIT_CLIENT_SECRET=...
# The Reddit account the bot posts as
REDDIT_USERNAME=JoinIvyEdge
REDDIT_PASSWORD=...
